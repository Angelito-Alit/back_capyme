generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                         Int                        @id @default(autoincrement())
  nombre                     String                     @db.VarChar(100)
  apellido                   String                     @db.VarChar(100)
  email                      String                     @unique(map: "email") @db.VarChar(150)
  password                   String                     @db.VarChar(255)
  telefono                   String?                    @db.VarChar(20)
  rol                        Rol
  activo                     Boolean?                   @default(true)
  fechaRegistro              DateTime?                  @default(now()) @map("fecha_registro") @db.Timestamp(0)
  ultimaSesion               DateTime?                  @map("ultima_sesion") @db.Timestamp(0)
  clabeInterbancaria         String?                    @map("clabe_interbancaria") @db.VarChar(18)
  whatsappPagos              String?                    @map("whatsapp_pagos") @db.VarChar(20)
  avisosCreados              Aviso[]                    @relation("AvisoCreador")
  avisosActualizados         Aviso[]                    @relation("AvisoActualizadoPor")
  cursosCreados              Curso[]
  enlacesCreados             EnlaceRecurso[]
  formularios_financiamiento FormularioFinanciamiento[]
  historialAcciones          HistorialAccion[]
  inscripcionesCurso         InscripcionCurso[]
  negocios                   Negocio[]
  pagosConfirmados           PagoInscripcion[]          @relation("pagosConfirmados")
  postulaciones              Postulacion[]
  preguntasCreadas           PreguntaFormulario[]
  programasCreados           Programa[]
  notificaciones Notificacion[]
  avisosLeidos  AvisoLeido[]
  accesosRecursos    AccesoRecurso[]
  pagosAccesoConfirmados PagoAccesoRecurso[] @relation("pagosAccesoConfirmados")
  jovenesJcf         JovenJcf[]

  @@index([activo], map: "idx_activo")
  @@index([email], map: "idx_email")
  @@index([rol], map: "idx_rol")
  @@map("usuarios")
}

model CategoriaNegocio {
  id            Int        @id @default(autoincrement())
  nombre        String     @unique(map: "nombre") @db.VarChar(100)
  descripcion   String?    @db.Text
  activo        Boolean?   @default(true)
  fechaCreacion DateTime?  @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  negocios      Negocio[]
  programas     Programa[]

  @@index([activo], map: "idx_activo")
  @@map("categorias_negocio")
}

model Negocio {
  id                         Int                        @id @default(autoincrement())
  usuarioId                  Int                        @map("usuario_id")
  nombreNegocio              String                     @map("nombre_negocio") @db.VarChar(200)
  categoriaId                Int                        @map("categoria_id")
  rfc                        String?                    @db.VarChar(13)
  razonSocial                String?                    @map("razon_social") @db.VarChar(200)
  giroComercial              String?                    @map("giro_comercial") @db.VarChar(150)
  direccion                  String?                    @db.Text
  ciudad                     String?                    @db.VarChar(100)
  estado                     String?                    @db.VarChar(100)
  codigoPostal               String?                    @map("codigo_postal") @db.VarChar(10)
  telefonoNegocio            String?                    @map("telefono_negocio") @db.VarChar(20)
  emailNegocio               String?                    @map("email_negocio") @db.VarChar(150)
  numeroEmpleados            Int?                       @default(0) @map("numero_empleados")
  anioFundacion              Int?                       @map("anio_fundacion") @db.Year
  descripcion                String?                    @db.Text
  activo                     Boolean?                   @default(true)
  fechaRegistro              DateTime?                  @default(now()) @map("fecha_registro") @db.Timestamp(0)
  fechaActualizacion         DateTime?                  @default(now()) @updatedAt @map("fecha_actualizacion") @db.Timestamp(0)
  formularios_financiamiento FormularioFinanciamiento[]
  inscripcionesCurso         InscripcionCurso[]
  usuario                    Usuario                    @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "negocios_ibfk_1")
  categoria                  CategoriaNegocio           @relation(fields: [categoriaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "negocios_ibfk_2")
  postulaciones              Postulacion[]
  jovenesJcf      JovenJcf[]

  @@index([activo], map: "idx_activo")
  @@index([categoriaId], map: "idx_categoria")
  @@index([usuarioId, activo], map: "idx_negocios_usuario_activo")
  @@index([nombreNegocio], map: "idx_nombre")
  @@index([usuarioId], map: "idx_usuario")
  @@map("negocios")
}

model Programa {
  id                 Int                @id @default(autoincrement())
  nombre             String             @db.VarChar(200)
  descripcion        String?            @db.Text
  tipoPrograma       String?            @map("tipo_programa") @db.VarChar(100)
  categoriaNegocioId Int?               @map("categoria_negocio_id")
  requisitos         String?            @db.Text
  beneficios         String?            @db.Text
  fechaInicio        DateTime?          @map("fecha_inicio") @db.Date
  fechaCierre        DateTime?          @map("fecha_cierre") @db.Date
  montoApoyo         Decimal?           @map("monto_apoyo") @db.Decimal(12, 2)
  activo             Boolean?           @default(true)
  creadoPor          Int                @map("creado_por")
  fechaCreacion      DateTime?          @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  fechaActualizacion DateTime?          @default(now()) @updatedAt @map("fecha_actualizacion") @db.Timestamp(0)
  estado             String?            @db.VarChar(100)
  municipio          String?            @db.VarChar(150)
  postulaciones      Postulacion[]
  categoria          CategoriaNegocio?  @relation(fields: [categoriaNegocioId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "programas_ibfk_1")
  creador            Usuario            @relation(fields: [creadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "programas_ibfk_2")
  programasPreguntas ProgramaPregunta[]

  @@index([creadoPor], map: "creado_por")
  @@index([activo], map: "idx_activo")
  @@index([categoriaNegocioId], map: "idx_categoria")
  @@index([fechaInicio, fechaCierre], map: "idx_fechas")
  @@index([activo, categoriaNegocioId], map: "idx_programas_activo_categoria")
  @@map("programas")
}

model PreguntaFormulario {
  id                 Int                    @id @default(autoincrement())
  pregunta           String                 @db.Text
  tipoRespuesta      TipoRespuesta          @map("tipo_respuesta")
  opcionesRespuesta  Json?                  @map("opciones_respuesta")
  obligatoria        Boolean?               @default(false)
  orden              Int?                   @default(0)
  categoria          String?                @db.VarChar(100)
  placeholder        String?                @db.VarChar(200)
  activa             Boolean?               @default(true)
  creadoPor          Int                    @map("creado_por")
  fechaCreacion      DateTime?              @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  creador            Usuario                @relation(fields: [creadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "preguntas_formulario_ibfk_1")
  programasPreguntas ProgramaPregunta[]
  respuestas         RespuestaPostulacion[]

  @@index([creadoPor], map: "creado_por")
  @@index([activa], map: "idx_activa")
  @@index([categoria], map: "idx_categoria")
  @@index([orden], map: "idx_orden")
  @@map("preguntas_formulario")
}

model ProgramaPregunta {
  id              Int                @id @default(autoincrement())
  programaId      Int                @map("programa_id")
  preguntaId      Int                @map("pregunta_id")
  orden           Int?               @default(0)
  activa          Boolean?           @default(true)
  fechaAsignacion DateTime?          @default(now()) @map("fecha_asignacion") @db.Timestamp(0)
  programa        Programa           @relation(fields: [programaId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "programas_preguntas_ibfk_1")
  pregunta        PreguntaFormulario @relation(fields: [preguntaId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "programas_preguntas_ibfk_2")

  @@unique([programaId, preguntaId], name: "unique_programa_pregunta", map: "unique_programa_pregunta")
  @@index([orden], map: "idx_orden")
  @@index([programaId], map: "idx_programa")
  @@index([preguntaId], map: "pregunta_id")
  @@map("programas_preguntas")
}

model Postulacion {
  id                 Int                    @id @default(autoincrement())
  negocioId          Int                    @map("negocio_id")
  programaId         Int                    @map("programa_id")
  usuarioId          Int                    @map("usuario_id")
  estado             EstadoPostulacion?     @default(pendiente)
  fechaPostulacion   DateTime?              @default(now()) @map("fecha_postulacion") @db.Timestamp(0)
  fechaActualizacion DateTime?              @default(now()) @updatedAt @map("fecha_actualizacion") @db.Timestamp(0)
  notasAdmin         String?                @map("notas_admin") @db.Text
  estadoGeo          String?                @map("estado_geo") @db.VarChar(100)
  municipio          String?                @db.VarChar(150)
  negocio            Negocio                @relation(fields: [negocioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "postulaciones_ibfk_1")
  programa           Programa               @relation(fields: [programaId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "postulaciones_ibfk_2")
  usuario            Usuario                @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "postulaciones_ibfk_3")
  respuestas         RespuestaPostulacion[]
  trabajadoresJCF    TrabajadorJCF[]
  jovenesJcf         JovenJcf[]

  @@unique([negocioId, programaId], name: "unique_negocio_programa", map: "unique_negocio_programa")
  @@index([estado], map: "idx_estado")
  @@index([fechaPostulacion], map: "idx_fecha")
  @@index([negocioId], map: "idx_negocio")
  @@index([estado, fechaPostulacion], map: "idx_postulaciones_estado_fecha")
  @@index([programaId], map: "idx_programa")
  @@index([usuarioId], map: "usuario_id")
  @@map("postulaciones")
}

model RespuestaPostulacion {
  id             Int                @id @default(autoincrement())
  postulacionId  Int                @map("postulacion_id")
  preguntaId     Int                @map("pregunta_id")
  respuesta      String?            @db.Text
  fechaRespuesta DateTime?          @default(now()) @map("fecha_respuesta") @db.Timestamp(0)
  postulacion    Postulacion        @relation(fields: [postulacionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "respuestas_postulacion_ibfk_1")
  pregunta       PreguntaFormulario @relation(fields: [preguntaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "respuestas_postulacion_ibfk_2")

  @@index([postulacionId], map: "idx_postulacion")
  @@index([preguntaId], map: "pregunta_id")
  @@map("respuestas_postulacion")
}

model TrabajadorJCF {
  id             Int         @id @default(autoincrement())
  postulacionId  Int         @map("postulacion_id")
  nombre         String      @db.VarChar(100)
  apellido       String      @db.VarChar(100)
  curp           String?     @unique(map: "curp") @db.VarChar(18)
  edad           Int?
  sexo           Sexo?
  telefono       String?     @db.VarChar(20)
  email          String?     @db.VarChar(150)
  nivelEstudios  String?     @map("nivel_estudios") @db.VarChar(100)
  areaFormacion  String?     @map("area_formacion") @db.VarChar(150)
  fechaInicio    DateTime?   @map("fecha_inicio") @db.Date
  fechaFin       DateTime?   @map("fecha_fin") @db.Date
  horasSemanales Int?        @default(30) @map("horas_semanales")
  tutorAsignado  String?     @map("tutor_asignado") @db.VarChar(150)
  activo         Boolean?    @default(true)
  fechaRegistro  DateTime?   @default(now()) @map("fecha_registro") @db.Timestamp(0)
  postulacion    Postulacion @relation(fields: [postulacionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "trabajadores_jcf_ibfk_1")

  @@index([activo], map: "idx_activo")
  @@index([postulacionId], map: "idx_postulacion")
  @@map("trabajadores_jcf")
}

model Curso {
  id                 Int                @id @default(autoincrement())
  titulo             String             @db.VarChar(200)
  descripcion        String?            @db.Text
  instructor         String?            @db.VarChar(150)
  duracionHoras      Int?               @map("duracion_horas")
  modalidad          Modalidad?         @default(online)
  fechaInicio        DateTime?          @map("fecha_inicio") @db.Date
  fechaFin           DateTime?          @map("fecha_fin") @db.Date
  cupoMaximo         Int?               @map("cupo_maximo")
  costo              Decimal?           @default(0.00) @db.Decimal(10, 2)
  activo             Boolean?           @default(true)
  creadoPor          Int                @map("creado_por")
  fechaCreacion      DateTime?          @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  fechaActualizacion DateTime?          @default(now()) @updatedAt @map("fecha_actualizacion") @db.Timestamp(0)
  creador            Usuario            @relation(fields: [creadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "cursos_ibfk_1")
  inscripciones      InscripcionCurso[]

  @@index([creadoPor], map: "creado_por")
  @@index([activo], map: "idx_activo")
  @@index([fechaInicio, fechaFin], map: "idx_fechas")
  @@map("cursos")
}

model InscripcionCurso {
  id               Int                @id @default(autoincrement())
  cursoId          Int                @map("curso_id")
  usuarioId        Int                @map("usuario_id")
  negocioId        Int?               @map("negocio_id")
  fechaInscripcion DateTime?          @default(now()) @map("fecha_inscripcion") @db.Timestamp(0)
  estado           EstadoInscripcion? @default(inscrito)
  calificacion     Int?
  comentarios      String?            @db.Text
  curso            Curso              @relation(fields: [cursoId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "inscripciones_curso_ibfk_1")
  usuario          Usuario            @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "inscripciones_curso_ibfk_2")
  negocio          Negocio?           @relation(fields: [negocioId], references: [id], onUpdate: NoAction, map: "inscripciones_curso_ibfk_3")
  pago             PagoInscripcion?

  @@unique([usuarioId, cursoId], name: "unique_usuario_curso", map: "unique_usuario_curso")
  @@index([cursoId], map: "idx_curso")
  @@index([estado], map: "idx_estado")
  @@index([usuarioId], map: "idx_usuario")
  @@index([negocioId], map: "negocio_id")
  @@map("inscripciones_curso")
}

model Aviso {
  id                    Int           @id @default(autoincrement())
  titulo                String        @db.VarChar(200)
  contenido             String        @db.Text
  tipo                  TipoAviso?    @default(informativo)
  destinatario          Destinatario? @default(clientes)
  linkExterno           String?       @map("link_externo") @db.VarChar(500)
  activo                Boolean?      @default(true)
  fechaPublicacion      DateTime?     @default(now()) @map("fecha_publicacion") @db.Timestamp(0)
  fechaExpiracion       DateTime?     @map("fecha_expiracion") @db.Timestamp(0)
  creadoPor             Int           @map("creado_por")
  actualizadoPor        Int?          @map("actualizado_por")
  creador               Usuario       @relation("AvisoCreador", fields: [creadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "avisos_ibfk_1")
  actualizadoPorUsuario Usuario?      @relation("AvisoActualizadoPor", fields: [actualizadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "avisos_ibfk_2")
  lecturas    AvisoLeido[]

  @@index([creadoPor], map: "creado_por")
  @@index([actualizadoPor], map: "actualizado_por")
  @@index([activo], map: "idx_activo")
  @@index([destinatario], map: "idx_destinatario")
  @@index([fechaPublicacion], map: "idx_fecha_pub")
  @@map("avisos")
}

model EnlaceRecurso {
  id            Int          @id @default(autoincrement())
  titulo        String       @db.VarChar(200)
  descripcion   String?      @db.Text
  url           String       @db.VarChar(500)
  tipo          TipoRecurso? @default(otro)
  categoria     String?      @db.VarChar(100)
  visiblePara   VisiblePara? @default(todos) @map("visible_para")
  activo        Boolean?     @default(true)
  costo              Decimal?     @default(0.00) @db.Decimal(10, 2)
  accesos            AccesoRecurso[]
  creadoPor     Int          @map("creado_por")
  fechaCreacion DateTime?    @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  creador       Usuario      @relation(fields: [creadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "enlaces_recursos_ibfk_1")

  @@index([creadoPor], map: "creado_por")
  @@index([activo], map: "idx_activo")
  @@index([categoria], map: "idx_categoria")
  @@index([tipo], map: "idx_tipo")
  @@map("enlaces_recursos")
}

model FormularioFinanciamiento {
  id                   Int                   @id @default(autoincrement())
  negocioId            Int                   @map("negocio_id")
  usuarioId            Int                   @map("usuario_id")
  montoSolicitado      Decimal?              @map("monto_solicitado") @db.Decimal(12, 2)
  plazoMeses           Int?                  @map("plazo_meses")
  destinoCredito       String?               @map("destino_credito") @db.Text
  ingresosMensuales    Decimal?              @map("ingresos_mensuales") @db.Decimal(12, 2)
  egresosMensuales     Decimal?              @map("egresos_mensuales") @db.Decimal(12, 2)
  tieneCreditosActivos Boolean?              @default(false) @map("tiene_creditos_activos")
  detallesCreditos     String?               @map("detalles_creditos") @db.Text
  estado               EstadoFinanciamiento? @default(enviado)
  fechaSolicitud       DateTime?             @default(now()) @map("fecha_solicitud") @db.Timestamp(0)
  negocio              Negocio               @relation(fields: [negocioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "formularios_financiamiento_ibfk_1")
  usuario              Usuario               @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "formularios_financiamiento_ibfk_2")

  @@index([estado], map: "idx_estado")
  @@index([negocioId], map: "idx_negocio")
  @@index([usuarioId], map: "usuario_id")
  @@map("formularios_financiamiento")
}

model ContactoCapyme {
  id                 Int       @id @default(autoincrement())
  telefono           String?   @db.VarChar(20)
  email              String?   @db.VarChar(150)
  direccion          String?   @db.Text
  horarioAtencion    String?   @map("horario_atencion") @db.VarChar(200)
  whatsapp           String?   @db.VarChar(20)
  facebookUrl        String?   @map("facebook_url") @db.VarChar(300)
  instagramUrl       String?   @map("instagram_url") @db.VarChar(300)
  linkedinUrl        String?   @map("linkedin_url") @db.VarChar(300)
  sitioWeb           String?   @map("sitio_web") @db.VarChar(300)
  fechaActualizacion DateTime? @default(now()) @updatedAt @map("fecha_actualizacion") @db.Timestamp(0)

  @@map("contacto_capyme")
}

model HistorialAccion {
  id            Int       @id @default(autoincrement())
  usuarioId     Int       @map("usuario_id")
  accion        String    @db.VarChar(100)
  tablaAfectada String?   @map("tabla_afectada") @db.VarChar(50)
  registroId    Int?      @map("registro_id")
  descripcion   String?   @db.Text
  ipAddress     String?   @map("ip_address") @db.VarChar(45)
  fechaAccion   DateTime? @default(now()) @map("fecha_accion") @db.Timestamp(0)
  usuario       Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "historial_acciones_ibfk_1")

  @@index([fechaAccion], map: "idx_fecha")
  @@index([tablaAfectada], map: "idx_tabla")
  @@index([usuarioId], map: "idx_usuario")
  @@map("historial_acciones")
}

model PagoInscripcion {
  id                Int              @id @default(autoincrement())
  inscripcionId     Int              @unique @map("inscripcion_id")
  referencia        String           @unique @db.VarChar(30)
  monto             Decimal          @db.Decimal(10, 2)
  tipoPago          TipoPago         @map("tipo_pago")
  estadoPago        EstadoPago       @default(pendiente) @map("estado_pago")
  confirmadoPor     Int?             @map("confirmado_por")
  fechaConfirmacion DateTime?        @map("fecha_confirmacion") @db.Timestamp(0)
  notas             String?          @db.Text
  fechaCreacion     DateTime?        @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  inscripcion       InscripcionCurso @relation(fields: [inscripcionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "pagos_inscripcion_ibfk_1")
  confirmador       Usuario?         @relation("pagosConfirmados", fields: [confirmadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "pagos_inscripcion_ibfk_2")

  @@index([estadoPago], map: "idx_estado_pago")
  @@index([inscripcionId], map: "idx_inscripcion")
  @@index([referencia], map: "idx_referencia")
  @@index([confirmadoPor], map: "pagos_inscripcion_ibfk_2")
  @@map("pagos_inscripcion")
}

model Notificacion {
  id            Int       @id @default(autoincrement())
  usuarioId     Int       @map("usuario_id")
  tipo          String    @db.VarChar(50)
  titulo        String    @db.VarChar(200)
  mensaje       String    @db.Text
  leida         Boolean   @default(false)
  fechaCreacion DateTime? @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  usuario       Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId], map: "idx_usuario")
  @@index([leida], map: "idx_leida")
  @@map("notificaciones")
}

model AvisoLeido {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @map("usuario_id")
  avisoId   Int      @map("aviso_id")
  fechaLeido DateTime? @default(now()) @map("fecha_leido") @db.Timestamp(0)
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  aviso     Aviso    @relation(fields: [avisoId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([usuarioId, avisoId], name: "unique_usuario_aviso", map: "unique_usuario_aviso")
  @@index([usuarioId], map: "idx_usuario")
  @@index([avisoId], map: "idx_aviso")
  @@map("avisos_leidos")
}

model AccesoRecurso {
  id                Int              @id @default(autoincrement())
  enlaceId          Int              @map("enlace_id")
  usuarioId         Int              @map("usuario_id")
  estado            EstadoAcceso     @default(pendiente)
  fechaSolicitud    DateTime?        @default(now()) @map("fecha_solicitud") @db.Timestamp(0)
  fechaActualizacion DateTime?       @default(now()) @updatedAt @map("fecha_actualizacion") @db.Timestamp(0)
  enlace            EnlaceRecurso    @relation(fields: [enlaceId], references: [id], onDelete: Cascade)
  usuario           Usuario          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  pago              PagoAccesoRecurso?

  @@unique([usuarioId, enlaceId], name: "unique_usuario_enlace")
  @@index([enlaceId], map: "idx_enlace")
  @@index([usuarioId], map: "idx_usuario")
  @@index([estado], map: "idx_estado")
  @@map("accesos_recursos")
}

model PagoAccesoRecurso {
  id                Int          @id @default(autoincrement())
  accesoId          Int          @unique @map("acceso_id")
  referencia        String       @unique @db.VarChar(30)
  monto             Decimal      @db.Decimal(10, 2)
  tipoPago          TipoPago     @map("tipo_pago")
  estadoPago        EstadoPago   @default(pendiente) @map("estado_pago")
  confirmadoPor     Int?         @map("confirmado_por")
  fechaConfirmacion DateTime?    @map("fecha_confirmacion") @db.Timestamp(0)
  notas             String?      @db.Text
  fechaCreacion     DateTime?    @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  acceso            AccesoRecurso @relation(fields: [accesoId], references: [id], onDelete: Cascade)
  confirmador       Usuario?     @relation("pagosAccesoConfirmados", fields: [confirmadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([estadoPago], map: "idx_estado_pago")
  @@index([accesoId], map: "idx_acceso")
  @@index([referencia], map: "idx_referencia")
  @@map("pagos_acceso_recursos")
}

model JovenJcf {
  id              Int         @id @default(autoincrement())
  nombre          String      @db.VarChar(100)
  apellido        String      @db.VarChar(100)
  correo          String?     @db.VarChar(150)
  telefono        String?     @db.VarChar(20)
  curp            String?     @unique(map: "curp_jcf") @db.VarChar(18)
  municipio       String?     @db.VarChar(150)
  negocioId       Int?        @map("negocio_id")
  negocio         Negocio?    @relation(fields: [negocioId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  fechaInicio     DateTime?   @map("fecha_inicio") @db.Date
  fechaTermino    DateTime?   @map("fecha_termino") @db.Date
  urlRecurso      String?     @map("url_recurso") @db.VarChar(500)
  activo          Boolean?    @default(true)
  usuarioId       Int         @map("usuario_id")
  postulacionId   Int?        @map("postulacion_id")
  fechaRegistro   DateTime?   @default(now()) @map("fecha_registro") @db.Timestamp(0)
  usuario         Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  postulacion     Postulacion? @relation(fields: [postulacionId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([activo], map: "idx_activo")
  @@index([usuarioId], map: "idx_usuario")
  @@index([postulacionId], map: "idx_postulacion")
  @@index([negocioId], map: "idx_negocio")
  @@map("jovenes_jcf")
}

